# No private keys needed — this app signs in the browser with MetaMask + Phantom.
#
# Optionally override the default RPC endpoints (also editable live in the UI's
# "RPC settings"). Public endpoints rate-limit; a dedicated Base RPC is
# recommended for the Base -> Solana prove step.
#
# NEXT_PUBLIC_* values are inlined at build time and visible in the browser
# bundle — only put public RPC URLs here, never secrets.

# NEXT_PUBLIC_BRIDGE_NETWORK=mainnet
# NEXT_PUBLIC_SITE_URL=https://base2sol.xyz
# NEXT_PUBLIC_REPOSITORY_URL=https://github.com/YOUR_ORG/YOUR_REPO
# NEXT_PUBLIC_BASE_RPC_URL=https://base-rpc.publicnode.com
# NEXT_PUBLIC_SOLANA_RPC_URL=https://solana-rpc.publicnode.com
# NEXT_PUBLIC_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# NEXT_PUBLIC_SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
